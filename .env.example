# 이 파일을 .env 로 복사하고 값을 채우세요 (.env 는 커밋 금지 — .gitignore 처리됨)

# 텔레그램 아카이브 (Mac mini HTTP MCP)
ARCHIVE_URL=https://macmini.taila0cca3.ts.net/
ARCHIVE_TOKEN=              # macmini 아카이브 서버 Bearer 토큰

# Gemini (1차 요약)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic (Opus 4.8 큐레이션)
ANTHROPIC_API_KEY=
OPUS_MODEL=claude-opus-4-8
